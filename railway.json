{
  "$schema": "https://railway.com/railway.schema.json",
  "deploy": {
    "healthcheckPath": "/accounts/login/",
    "healthcheckTimeout": 100,
    "startCommand": "./entrypoint.sh",
    "sleepApplication": false,
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "production": {
      "deploy": {
        "healthcheckPath": "/accounts/login/",
        "healthcheckTimeout": 100,
        "startCommand": "./entrypoint.sh",
        "sleepApplication": false,
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    },
    "pr": {
      "deploy": {
        "numReplicas": 1
      }
    }
  }
}
